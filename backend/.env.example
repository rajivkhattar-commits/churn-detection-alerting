# Churn detection API — copy to .env and adjust.
# Canonical joins: path to ask-wolt-mcp clone (loads schema.py / SCHEMA_DESCRIPTION).
# ASKWOLT_MCP_HOME=/Users/YOU/ask-wolt-mcp

# Optional: structured Enterprise definition (overrides repo data/enterprise_churn_definition.json)
# ENTERPRISE_DEFINITION_JSON={"text":"..."}

# Optional: canonical join paths from get_schema + ask_wolt (JSON object)
# CANONICAL_JOINS_JSON={"venue":{"fact_orders":"..."}}

# Optional: Snowflake read client for future SELECT-based feature loading only (no DML)
# SNOWFLAKE_ACCOUNT=
# SNOWFLAKE_USER=
# SNOWFLAKE_PASSWORD=
# SNOWFLAKE_WAREHOUSE=
# SNOWFLAKE_DATABASE=
# SNOWFLAKE_SCHEMA=
# SNOWFLAKE_ROLE=

# LLM for explanation agent (OpenAI-compatible)
# LLM_API_KEY=
# LLM_BASE_URL=
# LLM_MODEL=gpt-4o-mini

# Outreach: production uses AM routing from data/am_assignments.json (brand|country → email).
# ENVIRONMENT=production
# Non-production: UI "Email preview to me" uses POST /api/outreach with preview_to_email (fixed inbox in dev UI).
# Fallback when preview_to_email is not used (other clients):
# OUTREACH_DEV_EMAIL=you@company.com

# SMTP (required for bulk dry-run email and non–dry-run sends)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@company.com

# Slack bot token — required for bulk dry-run Slack digest (POST /api/outreach/bulk-preview)
# SLACK_BOT_TOKEN=
